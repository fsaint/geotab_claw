PORT=3000
PUBLIC_URL=https://your-vps.com

# Demo mode - uses mock Geotab data (auto-enabled if GEOTAB_DATABASE is empty)
DEMO_MODE=true

# Feature flag: use OpenClaw instead of OpenAI Realtime
USE_OPENCLAW=false

# Twilio
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_PHONE_NUMBER=+1234567890

# OpenAI (used for Realtime API and TTS/STT)
OPENAI_API_KEY=sk-xxx

# OpenClaw Gateway (when USE_OPENCLAW=true)
OPENCLAW_GATEWAY_URL=ws://localhost:18789
OPENCLAW_GATEWAY_TOKEN=

# TTS Provider: openai or elevenlabs
TTS_PROVIDER=openai
TTS_VOICE=alloy

# ElevenLabs (when TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# Geotab
GEOTAB_SERVER=my.geotab.com
GEOTAB_DATABASE=demo_danger_zone
GEOTAB_USERNAME=user@email.com
GEOTAB_PASSWORD=password

# Contacts
BOSS_PHONE=+1234567890
MIKE_PHONE=+1234567891
